# Site credentials (basic auth for UI + API)
PATCHWORK_USERNAME=admin
PATCHWORK_PASSWORD=changeme

# Site URL (used by reverse proxy and CORS)
PATCHWORK_URL=http://localhost
# PATCHWORK_URL=https://patchwork.example.com

# Encryption key for stored agent tokens (32-byte hex)
# Generate with: openssl rand -hex 32
PATCHWORK_ENCRYPTION_KEY=

# PostgreSQL
POSTGRES_USER=patchwork
POSTGRES_PASSWORD=patchwork
POSTGRES_DB=patchwork

# Ports (internal, Caddy handles external)
SERVER_PORT=3001
UI_PORT=3000
