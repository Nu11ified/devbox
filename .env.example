# ── Authentication ─────────────────────────────────────────────────
# GitHub OAuth (create at https://github.com/settings/developers)
# Callback URL: https://your-domain/api/auth/callback/github
# Required scopes: read:user, user:email, repo
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# better-auth session secret
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
UI_ORIGIN=http://localhost:3000

# Fallback basic auth (used when GitHub OAuth not configured)
PATCHWORK_USERNAME=admin
PATCHWORK_PASSWORD=changeme

# Encryption key for stored agent tokens (32-byte hex)
# Generate with: openssl rand -hex 32
PATCHWORK_ENCRYPTION_KEY=

# ── Database ──────────────────────────────────────────────────────
POSTGRES_USER=patchwork
POSTGRES_PASSWORD=patchwork
POSTGRES_DB=patchwork
DATABASE_URL=postgresql://patchwork:patchwork@localhost:5433/patchwork

# ── Redis (caching GitHub API responses) ──────────────────────────
REDIS_URL=redis://localhost:6379

# ── Ports (exposed on host) ──────────────────────────────────────
SERVER_PORT=3001
UI_PORT=3000

# ── Claude Subscription (Max/Pro) ────────────────────────────────
# Path to .claude config dir containing OAuth credentials
# Used for subscription-mode auth (no API key needed)
CLAUDE_CONFIG_DIR=~/.claude

# ── WebSocket ────────────────────────────────────────────────────
# Cross-origin WebSocket URL (set when UI and server are on different domains)
# NEXT_PUBLIC_WS_URL=wss://devserver.example.com

# ── Orchestrator ──────────────────────────────────────────────────
PATCHWORK_POLL_INTERVAL_MS=5000
PATCHWORK_MAX_CONCURRENT=5
PATCHWORK_STALL_TIMEOUT_MS=600000
