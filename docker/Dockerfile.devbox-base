# Patchwork Devbox Base Image
#
# Multi-stage build: stage 1 builds the sidecar, stage 2 creates the runtime image.
# Prerequisites: run `npm run build -w packages/sidecar` before building, or
# rely on stage 1 to build it from source.
#
# Security: This image runs untrusted agent code. Container isolation is enforced
# at runtime via Docker flags (see docker-compose or devbox manager):
#   --cap-drop ALL --security-opt no-new-privileges:true --network none
# See: https://platform.claude.com/docs/en/agent-sdk/secure-deployment

# --- Stage 1: Build the sidecar ---
FROM oven/bun:1 AS builder

RUN apt-get update && \
    apt-get install -y --no-install-recommends python3 make g++ && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /build

# Copy root workspace files
COPY package.json bun.lock tsconfig.base.json ./
COPY packages/sidecar/package.json packages/sidecar/tsconfig.json packages/sidecar/
COPY packages/sidecar/src packages/sidecar/src

# Install dependencies and build sidecar
RUN bun install && \
    bun run --filter @patchwork/sidecar build

# --- Stage 2: Runtime image ---
FROM node:20-slim

# Install common dev tools
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      git \
      curl \
      jq \
      ca-certificates \
      openssh-client && \
    rm -rf /var/lib/apt/lists/*

# Set up workspace directory
WORKDIR /workspace

# Copy built sidecar from builder stage
COPY --from=builder /build/packages/sidecar/dist /opt/sidecar/dist
COPY --from=builder /build/packages/sidecar/package.json /opt/sidecar/
COPY --from=builder /build/packages/sidecar/node_modules /opt/sidecar/node_modules

# Configure sidecar
ENV SIDECAR_PORT=9999
EXPOSE 9999

# Git configuration for commits inside devbox
RUN git config --system user.email "patchwork@devbox" && \
    git config --system user.name "Patchwork Devbox"

# Security: Create a non-root user for running agent workloads.
# The agent process should NOT run as root inside the container.
# Container runtime flags (--cap-drop ALL, --network none, etc.) are
# applied by the DevboxManager when creating containers.
RUN groupadd --gid 1000 agent && \
    useradd --uid 1000 --gid agent --shell /bin/bash --create-home agent && \
    chown -R agent:agent /workspace

# Switch to non-root user for agent execution
USER agent

# Default command: start the sidecar
CMD ["node", "/opt/sidecar/dist/index.js"]
