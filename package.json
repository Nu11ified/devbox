{
  "name": "patchwork",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun --filter '*' build",
    "test": "bun --filter '*' test",
    "dev:server": "bun --filter @patchwork/server dev",
    "dev:sidecar": "bun --filter @patchwork/sidecar dev",
    "dev:ui": "bun --filter @patchwork/ui dev"
  }
}
